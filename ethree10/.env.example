# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ethree10_dev?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ethree10_dev?schema=public"

# ─── Auth.js ────────────────────────────────────────────────────────────────
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional in dev, required in prod)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="Ethree10 <noreply@ethree10.r4c.global>"

# ─── Redis (BullMQ / Upstash) ───────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Integrations ────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting per-integration secrets (32-byte hex)
INTEGRATION_SECRET_KEY="generate-with-openssl-rand-hex-32"

# ─── Storage (Supabase) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Monitoring (Sentry) ─────────────────────────────────────────────────────
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
NEXT_PUBLIC_SENTRY_DSN=""

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
