# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ethree10_dev?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ethree10_dev?schema=public"

# ─── Auth.js ────────────────────────────────────────────────────────────────
AUTH_SECRET="replace-with-openssl-rand-base64-32"
CRON_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional in dev, required in prod)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_replace_me"
EMAIL_FROM="Ethree10 <noreply@ethree10.r4c.global>"

# ─── Redis (BullMQ / Upstash) ───────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Integrations ────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting per-integration secrets (64 hex chars)
INTEGRATION_SECRET_KEY="aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"

# ─── Storage (S3 / MinIO compatible) ────────────────────────────────────────
STORAGE_ENDPOINT="http://127.0.0.1:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="ethree10-dev"
STORAGE_PUBLIC_URL="http://localhost:3000/files"
NEXT_PUBLIC_STORAGE_URL="http://localhost:3000/files"

# ─── Monitoring (Sentry) ─────────────────────────────────────────────────────
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
NEXT_PUBLIC_SENTRY_DSN=""

# ─── Payments (Paystack — the only payment provider for v1.0) ────────────────
# Required in production; omitting it in dev falls back to a fake key so the app boots.
PAYSTACK_SECRET_KEY=""
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""

# ─── Payments (Stripe — DISABLED for v1.0) ───────────────────────────────────
# Leave blank. Setting both re-enables the Stripe service/webhook (not used in v1.0).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─── WhatsApp (Twilio) ───────────────────────────────────────────────────────
# Optional in dev (messages are logged to console). Required in prod for delivery.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# ─── Product analytics (PostHog) ─────────────────────────────────────────────
# With no key, analytics is a no-op. Set in prod to capture events.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
