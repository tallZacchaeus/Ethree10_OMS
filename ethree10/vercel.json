{
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "SKIP_ENV_VALIDATION": "false"
  },
  "functions": {
    "app/api/trpc/[trpc]/route.ts": { "maxDuration": 30 },
    "app/api/reports/**": { "maxDuration": 60 },
    "app/api/webhooks/**": { "maxDuration": 30 }
  }
}
