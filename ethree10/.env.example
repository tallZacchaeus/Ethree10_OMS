# ─── Redis (BullMQ / Upstash) ───────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Integrations ────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting per-integration secrets (64 hex chars)
INTEGRATION_SECRET_KEY="aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"

# ─── Storage (S3 / MinIO compatible) ────────────────────────────────────────
